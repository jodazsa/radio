[Unit]
Description=RSS Feed Generator for Radio Station Info
After=network.target

[Service]
Type=simple
User=radio
ExecStartPre=/usr/local/bin/rss-generator
ExecStart=/bin/bash -c 'while inotifywait -e modify /home/radio/.radio-state; do /usr/local/bin/rss-generator; done'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
