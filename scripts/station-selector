#!/usr/bin/env python3
"""
station-selector: Monitor BCD rotary switches and change stations
Reads two 10-position BCD switches: one for bank (0-9) and one for station (0-9)
"""

import RPi.GPIO as GPIO
import subprocess
import time
import signal
import sys
import os
import yaml

# Load configuration
CONFIG_FILE = "/home/radio/hardware-config.yaml"

def load_config():
    """Load hardware configuration"""
    try:
        with open(CONFIG_FILE, 'r') as f:
            return yaml.safe_load(f)
    except:
        # Fallback to defaults if config not found
        print(f"Warning: Could not load {CONFIG_FILE}, using defaults")
        return {
            'gpio': {
                'station_switch': {'bit0': 10, 'bit1': 9, 'bit2': 22, 'bit3': 17},
                'bank_switch': {'bit0': 5, 'bit1': 6, 'bit2': 13, 'bit3': 11}
            }
        }

config = load_config()

# Configuration
STATION_BCD_PINS = [
    config['gpio']['station_switch']['bit0'],
    config['gpio']['station_switch']['bit1'],
    config['gpio']['station_switch']['bit2'],
    config['gpio']['station_switch']['bit3']
]
BANK_BCD_PINS = [
    config['gpio']['bank_switch']['bit0'],
    config['gpio']['bank_switch']['bit1'],
    config['gpio']['bank_switch']['bit2'],
    config['gpio']['bank_switch']['bit3']
]
STATE_FILE = "/home/radio/.radio-state"
CHECK_INTERVAL = 0.1  # How often to check switch position (seconds)

# Current state
current_bank = 0
current_station = 0

def read_bcd_switch(pins):
    """Read the current position (0-9) from a BCD switch"""
    value = 0
    for i, pin in enumerate(pins):
        # Pins are pulled HIGH, switch pulls them LOW
        # So we need to invert: if LOW (0), bit is active (1)
        if GPIO.input(pin) == GPIO.LOW:
            value |= (1 << i)
    return value

def load_state():
    """Load current bank and station from state file"""
    global current_bank, current_station
    try:
        if os.path.exists(STATE_FILE):
            with open(STATE_FILE, 'r') as f:
                for line in f:
                    if line.startswith('current_bank='):
                        current_bank = int(line.split('=')[1].strip())
                    elif line.startswith('current_station='):
                        current_station = int(line.split('=')[1].strip())
    except:
        pass
    print(f"Loaded state: Bank {current_bank}, Station {current_station}")

def save_state(bank, station):
    """Save current bank and station to state file"""
    try:
        with open(STATE_FILE, 'w') as f:
            f.write(f"current_bank={bank}\n")
            f.write(f"current_station={station}\n")
    except:
        pass

def play_station(bank, station):
    """Play a station using radio-play"""
    msg = f"Switching to Bank {bank}, Station {station}"
    print(msg)
    # Also write to a log file
    try:
        with open('/home/radio/station.log', 'a') as f:
            import datetime
            timestamp = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            f.write(f"{timestamp} - {msg}\n")
    except:
        pass
    
    # Call radio-play and capture its output
    result = subprocess.run(['radio-play', str(bank), str(station)],
                           capture_output=True, text=True)
    if result.stdout:
        print(result.stdout.strip())
        try:
            with open('/home/radio/station.log', 'a') as f:
                f.write(f"{result.stdout.strip()}\n")
        except:
            pass
    
    save_state(bank, station)

def signal_handler(sig, frame):
    """Handle Ctrl+C gracefully"""
    print("\nStation selector stopped")
    GPIO.cleanup()
    sys.exit(0)

def main():
    global current_bank, current_station
    
    # Set up signal handler
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    
    # Set up GPIO
    GPIO.setmode(GPIO.BCM)
    GPIO.setwarnings(False)
    
    # Configure station selector BCD pins as inputs with pull-up resistors
    for pin in STATION_BCD_PINS:
        GPIO.setup(pin, GPIO.IN, pull_up_down=GPIO.PUD_UP)
    
    # Configure bank selector BCD pins as inputs with pull-up resistors
    for pin in BANK_BCD_PINS:
        GPIO.setup(pin, GPIO.IN, pull_up_down=GPIO.PUD_UP)
    
    # Give GPIO time to stabilize
    time.sleep(0.5)
    
    print("Starting station selector...")
    
    # Load current state
    load_state()
    
    # Get initial switch positions
    last_bank_position = read_bcd_switch(BANK_BCD_PINS)
    last_station_position = read_bcd_switch(STATION_BCD_PINS)
    print(f"Initial bank switch position: {last_bank_position}")
    print(f"Initial station switch position: {last_station_position}")
    
    print("Station selector ready. Turn switches to change bank/station.")
    
    try:
        while True:
            # Read current switch positions
            bank_position = read_bcd_switch(BANK_BCD_PINS)
            station_position = read_bcd_switch(STATION_BCD_PINS)
            
            # Check if bank switch changed
            if bank_position != last_bank_position:
                print(f"Bank switch moved to position {bank_position}")
                
                # If bank changed, play station 0 of new bank
                # Or play the current station position if it's valid
                if bank_position != current_bank:
                    current_bank = bank_position
                    # Use current station position or 0 if invalid
                    play_station(current_bank, station_position)
                    current_station = station_position
                
                last_bank_position = bank_position
            
            # Check if station switch changed
            if station_position != last_station_position:
                print(f"Station switch moved to position {station_position}")
                
                # Update to new station in current bank
                if station_position != current_station:
                    play_station(current_bank, station_position)
                    current_station = station_position
                
                last_station_position = station_position
            
            time.sleep(CHECK_INTERVAL)
            
    except Exception as e:
        print(f"Error: {e}")
        GPIO.cleanup()
        sys.exit(1)

if __name__ == '__main__':
    main()
