#!/usr/bin/env python3
"""
volume-control: Monitor rotary encoder and control system volume
Controls both MPD (streams) and hardware volume (MPV/everything)
Button press toggles play/pause
"""

import board
from adafruit_seesaw.seesaw import Seesaw
from adafruit_seesaw.rotaryio import IncrementalEncoder
from digitalio import Direction
import subprocess
import time
import signal
import sys

# Configuration
ENCODER_ADDR = 0x36
VOLUME_STEP = 4  # How much to change volume per encoder click
MIN_VOLUME = 50
MAX_VOLUME = 100
DEFAULT_VOLUME = 60
BUTTON_PIN = 24  # Encoder button pin on seesaw

# Global volume state
current_volume = DEFAULT_VOLUME

def get_current_volume():
    """Get current volume from MPD"""
    try:
        result = subprocess.run(['mpc', 'volume'], capture_output=True, text=True)
        # Output format: "volume: 50%"
        if 'volume:' in result.stdout:
            vol_str = result.stdout.split(':')[1].strip().rstrip('%')
            return int(vol_str)
    except:
        pass
    return DEFAULT_VOLUME

def set_volume(volume):
    """Set volume for both MPD and ALSA hardware"""
    volume = max(MIN_VOLUME, min(MAX_VOLUME, volume))
    
    # Set MPD volume (for streams)
    subprocess.run(['mpc', 'volume', str(volume)], 
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    # Set ALSA Digital volume (for MPV and everything else)
    # Digital control goes from 0-207, map our 0-100 to that range
    alsa_volume = int((volume / 100.0) * 207)
    subprocess.run(['amixer', 'set', 'Digital', str(alsa_volume)],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    print(f"Volume: {volume}%")
    return volume

def is_mpd_playing():
    """Check if MPD is currently playing"""
    try:
        result = subprocess.run(['mpc', 'status'], capture_output=True, text=True)
        return '[playing]' in result.stdout
    except:
        return False

def is_mpv_playing():
    """Check if MPV is currently running"""
    try:
        result = subprocess.run(['pgrep', 'mpv'], capture_output=True)
        return result.returncode == 0
    except:
        return False

def is_mpv_paused():
    """Check if MPV is paused via IPC socket"""
    try:
        import socket
        import json
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.connect('/tmp/mpv-socket')
        sock.sendall(b'{ "command": ["get_property", "pause"] }\n')
        response = sock.recv(1024).decode()
        sock.close()
        data = json.loads(response)
        return data.get('data', False)
    except:
        return False

def toggle_playback():
    """Toggle play/pause for MPD (streams) and MPV (recorded audio)"""
    mpd_playing = is_mpd_playing()
    mpv_playing = is_mpv_playing()
    
    if mpd_playing:
        # MPD is playing, pause it
        subprocess.run(['mpc', 'pause'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print("Paused (MPD)")
    elif mpv_playing:
        # MPV is playing or paused, toggle via IPC socket
        try:
            import socket
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            sock.connect('/tmp/mpv-socket')
            # Send pause toggle command
            sock.sendall(b'{ "command": ["cycle", "pause"] }\n')
            sock.close()
            
            # Check new state
            if is_mpv_paused():
                print("Paused (MPV)")
            else:
                print("Playing (MPV)")
        except Exception as e:
            print(f"Error controlling MPV: {e}")
    else:
        # Check if MPD has something paused
        result = subprocess.run(['mpc', 'status'], capture_output=True, text=True)
        if '[paused]' in result.stdout:
            # Resume paused MPD stream
            subprocess.run(['mpc', 'play'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            print("Resumed (MPD)")
        else:
            print("Nothing playing - use radio-play to start a station")

def signal_handler(sig, frame):
    """Handle Ctrl+C gracefully"""
    print("\nVolume control stopped")
    sys.exit(0)

def main():
    global current_volume
    
    # Set up signal handler
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    
    # Initialize I2C and encoder
    print("Starting volume control...")
    i2c = board.I2C()
    seesaw = Seesaw(i2c, addr=ENCODER_ADDR)
    encoder = IncrementalEncoder(seesaw)
    
    # Set up button
    seesaw.pin_mode(BUTTON_PIN, seesaw.INPUT_PULLUP)
    
    # Get initial volume from MPD
    current_volume = get_current_volume()
    print(f"Initial volume: {current_volume}%")
    
    # Set initial volume to sync everything
    set_volume(current_volume)
    
    last_position = encoder.position
    button_held = False
    
    print("Volume control ready. Turn encoder to adjust volume, press to play/pause.")
    
    try:
        while True:
            # Handle encoder rotation
            position = encoder.position
            
            if position != last_position:
                # Calculate volume change (reversed direction)
                delta = position - last_position
                current_volume += (delta * -1) * VOLUME_STEP
                
                # Set new volume
                current_volume = set_volume(current_volume)
                
                last_position = position
            
            # Handle button press
            button_pressed = not seesaw.digital_read(BUTTON_PIN)
            
            if button_pressed and not button_held:
                # Button just pressed
                toggle_playback()
                button_held = True
            elif not button_pressed and button_held:
                # Button released
                button_held = False
            
            time.sleep(0.01)
            
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

if __name__ == '__main__':
    main()
