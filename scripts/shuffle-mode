#!/usr/bin/env python3
"""
shuffle-mode: Randomly changes stations when switch is ON
"""

import RPi.GPIO as GPIO
import subprocess
import time
import random
import yaml
import signal
import sys

# Load configuration
CONFIG_FILE = "/home/radio/hardware-config.yaml"

def load_config():
    """Load hardware configuration"""
    try:
        with open(CONFIG_FILE, 'r') as f:
            config = yaml.safe_load(f)
            return {
                'gpio_pin': config['gpio'].get('shuffle_switch', 24),
                'interval': config.get('shuffle_mode', {}).get('interval_seconds', 45),
                'enabled_banks': config.get('shuffle_mode', {}).get('enabled_banks', list(range(10))),
                'stations_yaml': config['paths']['stations_yaml']
            }
    except:
        # Fallback to defaults
        return {
            'gpio_pin': 24,
            'interval': 45,
            'enabled_banks': list(range(10)),
            'stations_yaml': '/home/radio/stations.yaml'
        }

config = load_config()

# Configuration
SHUFFLE_SWITCH_PIN = config['gpio_pin']
SHUFFLE_INTERVAL = config['interval']
ENABLED_BANKS = config['enabled_banks']
STATIONS_YAML = config['stations_yaml']

# Global state
shutdown_flag = False

def signal_handler(sig, frame):
    """Handle shutdown signals"""
    global shutdown_flag
    print("\nShutdown signal received")
    shutdown_flag = True

def load_stations():
    """Load available stations from YAML"""
    try:
        with open(STATIONS_YAML, 'r') as f:
            data = yaml.safe_load(f)
        return data['banks']
    except Exception as e:
        print(f"Error loading stations: {e}")
        return {}

def get_random_station(banks):
    """Get a random valid bank and station"""
    # Filter to enabled banks that have stations
    valid_banks = [b for b in ENABLED_BANKS if b in banks and banks[b].get('stations')]
    
    if not valid_banks:
        return None, None
    
    # Pick random bank
    bank = random.choice(valid_banks)
    
    # Pick random station from that bank
    stations = banks[bank]['stations']
    station_nums = list(stations.keys())
    
    if not station_nums:
        return None, None
    
    station = random.choice(station_nums)
    
    return bank, station

def is_switch_on():
    """Check if shuffle switch is ON"""
    try:
        # Switch is ON when pin reads LOW (pulled to ground)
        return GPIO.input(SHUFFLE_SWITCH_PIN) == GPIO.LOW
    except:
        return False

def play_random_station(banks):
    """Play a random station"""
    bank, station = get_random_station(banks)
    
    if bank is None or station is None:
        print("No valid stations found")
        return False
    
    print(f"Shuffling to Bank {bank}, Station {station}: {banks[bank]['stations'][station]['name']}")
    
    try:
        subprocess.run(['radio-play', str(bank), str(station)],
                      stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL)
        return True
    except Exception as e:
        print(f"Error playing station: {e}")
        return False

def main():
    global shutdown_flag
    
    # Set up signal handlers
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    
    # Set up GPIO
    GPIO.setmode(GPIO.BCM)
    GPIO.setwarnings(False)
    GPIO.setup(SHUFFLE_SWITCH_PIN, GPIO.IN, pull_up_down=GPIO.PUD_UP)
    
    # Give GPIO time to stabilize
    time.sleep(0.5)
    
    print(f"Shuffle mode starting (GPIO {SHUFFLE_SWITCH_PIN}, interval: {SHUFFLE_INTERVAL}s)")
    print(f"Enabled banks: {ENABLED_BANKS}")
    
    # Load stations
    banks = load_stations()
    
    if not banks:
        print("Error: Could not load stations")
        return 1
    
    print(f"Loaded {len(banks)} banks")
    
    last_shuffle_time = 0
    was_on = False
    
    try:
        while not shutdown_flag:
            switch_on = is_switch_on()
            current_time = time.time()
            
            # Detect switch turning ON
            if switch_on and not was_on:
                print("Shuffle mode ENABLED")
                # Immediately play a random station
                play_random_station(banks)
                last_shuffle_time = current_time
            
            # Detect switch turning OFF
            if not switch_on and was_on:
                print("Shuffle mode DISABLED")
            
            # If switch is ON and interval has passed, shuffle again
            if switch_on and (current_time - last_shuffle_time) >= SHUFFLE_INTERVAL:
                play_random_station(banks)
                last_shuffle_time = current_time
            
            was_on = switch_on
            time.sleep(0.5)  # Check switch state twice per second
    
    except Exception as e:
        print(f"Error: {e}")
        return 1
    finally:
        GPIO.cleanup()
        print("Shuffle mode stopped")
    
    return 0

if __name__ == '__main__':
    sys.exit(main())
