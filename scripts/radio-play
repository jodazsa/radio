#!/usr/bin/env python3
"""
radio-play: Internet radio station player for Raspberry Pi
Usage: radio-play <bank> <station>
Example: radio-play 3 4
"""

import sys
import yaml
import subprocess
import os
import random
from pathlib import Path

# Load configuration
CONFIG_FILE = "/home/radio/hardware-config.yaml"

def load_config():
    """Load hardware configuration"""
    try:
        with open(CONFIG_FILE, 'r') as f:
            return yaml.safe_load(f)
    except:
        # Fallback to defaults if config not found
        return {
            'audio': {'card': 1, 'device': 0},
            'audio_processing': {'mono_downmix': True}
        }

config = load_config()

# Configuration
YAML_FILE = "/home/radio/stations.yaml"
AUDIO_BASE_DIR = "/home/radio/audio"
AUDIO_CARD = config['audio']['card']
AUDIO_DEVICE = config['audio']['device']
MONO_DOWNMIX = config['audio_processing']['mono_downmix']

def load_stations():
    """Load and parse the stations YAML file"""
    try:
        with open(YAML_FILE, 'r') as f:
            data = yaml.safe_load(f)
        return data['banks']
    except FileNotFoundError:
        print(f"Error: Stations file not found at {YAML_FILE}")
        sys.exit(1)
    except yaml.YAMLError as e:
        print(f"Error parsing YAML file: {e}")
        sys.exit(1)

def stop_all_playback():
    """Stop MPD playback"""
    subprocess.run(['mpc', 'stop'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(['mpc', 'clear'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def play_stream(url):
    """Play an internet radio stream using MPD"""
    subprocess.run(['mpc', 'clear'], check=True)
    subprocess.run(['mpc', 'add', url], check=True)
    subprocess.run(['mpc', 'play'], check=True)

def seek_to_random_position():
    """Seek to a random position in the currently playing track"""
    try:
        # Let it start playing, then get status
        import time
        time.sleep(0.5)
        
        result = subprocess.run(['mpc', 'status'], capture_output=True, text=True)
        status = result.stdout
        
        # Parse duration from status line like "[playing] #1/1   0:05/3:47 (2%)"
        for line in status.split('\n'):
            if '/' in line and ':' in line:
                # Look for time format like "0:05/3:47"
                parts = line.split()
                for part in parts:
                    if '/' in part and ':' in part:
                        # Extract total time (after the /)
                        current, total = part.split('/')
                        
                        # Parse total time (e.g., "3:47")
                        time_parts = total.split(':')
                        if len(time_parts) == 2:
                            minutes, seconds = int(time_parts[0]), int(time_parts[1])
                            total_seconds = minutes * 60 + seconds
                            
                            # Seek to random position (up to 90% through to avoid end)
                            random_pos = random.randint(0, int(total_seconds * 0.9))
                            seek_minutes = random_pos // 60
                            seek_seconds = random_pos % 60
                            seek_time = f"{seek_minutes}:{seek_seconds:02d}"
                            
                            print(f"Seeking to random position: {seek_time}")
                            subprocess.run(['mpc', 'seek', seek_time])
                            return True
        return False
    except Exception as e:
        print(f"Warning: Could not seek to random position: {e}")
        return False

def play_mp3_loop_random_start(filepath):
    """Play a single MP3 file with MPD, starting at a random position, looping forever"""
    full_path = os.path.join(AUDIO_BASE_DIR, filepath)
    
    if not os.path.exists(full_path):
        print(f"Error: Audio file not found: {full_path}")
        sys.exit(1)
    
    print(f"Playing file loop: {filepath}")
    
    # Clear playlist and add file
    subprocess.run(['mpc', 'clear'], check=True)
    subprocess.run(['mpc', 'add', full_path], check=True)
    
    # Enable repeat mode for looping
    subprocess.run(['mpc', 'repeat', 'on'], check=True)
    
    # Start playback
    subprocess.run(['mpc', 'play'], check=True)
    
    # Seek to random position
    seek_to_random_position()

def play_mp3_dir_random_start_then_in_order(dirpath):
    """Play files from a directory with MPD: random start, then continue in order, looping"""
    full_path = os.path.join(AUDIO_BASE_DIR, dirpath)
    
    if not os.path.exists(full_path):
        print(f"Error: Audio directory not found: {full_path}")
        sys.exit(1)
    
    # Get all MP3 files in directory (and other audio formats)
    audio_extensions = {'.mp3', '.flac', '.ogg', '.m4a', '.wav'}
    audio_files = sorted([
        os.path.join(full_path, f) for f in os.listdir(full_path)
        if os.path.isfile(os.path.join(full_path, f)) and 
        os.path.splitext(f)[1].lower() in audio_extensions
    ])
    
    if not audio_files:
        print(f"Error: No audio files found in {full_path}")
        sys.exit(1)
    
    print(f"Playing directory: {dirpath} ({len(audio_files)} files)")
    
    # Pick a random starting file
    start_index = random.randint(0, len(audio_files) - 1)
    
    # Create playlist: starting file + all others in order
    playlist = audio_files[start_index:] + audio_files[:start_index]
    
    # Clear and build playlist in MPD
    subprocess.run(['mpc', 'clear'], check=True)
    for audio_file in playlist:
        subprocess.run(['mpc', 'add', audio_file], 
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    # Enable repeat mode to loop through all files
    subprocess.run(['mpc', 'repeat', 'on'], check=True)
    
    # Start playback
    subprocess.run(['mpc', 'play'], check=True)
    
    # Seek to random position in the first file
    seek_to_random_position()

def main():
    if len(sys.argv) != 3:
        print("Usage: radio-play <bank> <station>")
        print("Example: radio-play 3 4")
        sys.exit(1)
    
    try:
        bank_num = int(sys.argv[1])
        station_num = int(sys.argv[2])
    except ValueError:
        print("Error: Bank and station must be numbers")
        sys.exit(1)
    
    # Load stations
    banks = load_stations()
    
    # Validate bank number
    if bank_num not in banks:
        print(f"Error: Bank {bank_num} not found")
        print(f"Available banks: {', '.join(map(str, sorted(banks.keys())))}")
        sys.exit(1)
    
    bank = banks[bank_num]
    
    # Validate station number
    if station_num not in bank['stations']:
        print(f"Error: Station {station_num} not found in bank {bank_num} ({bank['name']})")
        print(f"Available stations: {', '.join(map(str, sorted(bank['stations'].keys())))}")
        sys.exit(1)
    
    station = bank['stations'][station_num]
    
    # Check if we're already playing this exact station
    # This prevents unnecessary restarts when switch wiggles on same position
    state_file = "/home/radio/.radio-state"
    try:
        if os.path.exists(state_file):
            with open(state_file, 'r') as f:
                current_bank = None
                current_station = None
                for line in f:
                    if line.startswith('current_bank='):
                        current_bank = int(line.split('=')[1].strip())
                    elif line.startswith('current_station='):
                        current_station = int(line.split('=')[1].strip())
                
                if current_bank == bank_num and current_station == station_num:
                    print(f"Already playing: {bank['name']} - {station['name']}")
                    print("(Not restarting)")
                    sys.exit(0)
    except:
        pass  # If state check fails, just continue to play
    
    # Stop any currently playing audio
    stop_all_playback()
    
    # Display what we're playing
    print(f"Playing: {bank['name']} - {station['name']}")
    
    # Save state for station selector
    try:
        with open('/home/radio/.radio-state', 'w') as f:
            f.write(f"current_bank={bank_num}\n")
            f.write(f"current_station={station_num}\n")
    except:
        pass  # Not critical if state file fails
    
    # Play based on type
    station_type = station['type']
    
    if station_type == 'stream':
        play_stream(station['url'])
    elif station_type == 'mp3_loop_random_start':
        play_mp3_loop_random_start(station['file'])
    elif station_type == 'mp3_dir_random_start_then_in_order':
        play_mp3_dir_random_start_then_in_order(station['dir'])
    else:
        print(f"Error: Unknown station type: {station_type}")
        sys.exit(1)

if __name__ == '__main__':
    main()
